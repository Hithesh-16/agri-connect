# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/kisan_connect?schema=public"

# Authentication
JWT_SECRET="generate-a-64-char-random-string-here"

# Server
PORT=5000
NODE_ENV=development

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# External APIs (optional - falls back to mock data if not set)
OPENWEATHERMAP_API_KEY=
AGMARKNET_API_KEY=
