generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

enum Role {
  FARMER
  TRADER
  DEALER
  CORPORATE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum CropCategory {
  cereal
  pulse
  cash
  spice
  vegetable
}

enum NewsCategory {
  market
  policy
  weather
  advisory
}

model User {
  id             String      @id @default(cuid())
  mobile         String      @unique
  aadhaar        String?
  firstName      String?
  surname        String?
  role           Role?
  houseNo        String?
  street         String?
  village        String?
  post           String?
  mandal         String?
  district       String?
  state          String?
  country        String?     @default("India")
  dob            DateTime?
  gender         Gender?
  language       String?     @default("en")
  updatesConsent Boolean     @default(false)
  profilePhoto   String?
  lastActive     DateTime    @default(now())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  crops              UserCrop[]
  mandis             UserMandi[]
  priceAlerts        PriceAlert[]
  calendarTasks      UserCalendarTask[]
  listings           Listing[]
  inquiriesSent      Inquiry[] @relation("inquiriesSent")
  communityPosts     CommunityPost[]
  communityComments  CommunityComment[]
  refreshTokens      RefreshToken[]
  userRoles          UserRole[]
  auditLogs          AuditLog[]
  serviceProvider    ServiceProvider?
  wallet             Wallet?
  organizationId     String?
  organization       Organization? @relation(fields: [organizationId], references: [id])
  farmerBookings     Booking[]          @relation("FarmerBookings")
  farmerChats        ChatConversation[] @relation("FarmerChats")
  notifications      Notification[]
  deviceTokens       DeviceToken[]
  jobPostings        JobPosting[]

  @@map("users")
}

model RefreshToken {
  id            String   @id @default(cuid())
  token         String   @unique
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceInfo    String?
  ipAddress     String?
  expiresAt     DateTime
  revoked       Boolean  @default(false)
  revokedAt     DateTime?
  replacedById  String?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ─── RBAC SYSTEM ─────────────────────────────────────────

model RoleDefinition {
  id           String   @id @default(cuid())
  name         String   @unique // SUPER_ADMIN, FARMER, VENDOR, etc.
  displayName  Json     // { en: "Farmer", te: "రైతు", hi: "किसान" }
  description  String?
  isSystem     Boolean  @default(true) // System roles can't be deleted
  parentId     String?
  parent       RoleDefinition?  @relation("RoleHierarchy", fields: [parentId], references: [id])
  children     RoleDefinition[] @relation("RoleHierarchy")
  permissions  RolePermission[]
  userRoles    UserRole[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("role_definitions")
}

model Permission {
  id          String   @id @default(cuid())
  resource    String   // e.g., "bookings", "services", "users", "payments"
  action      String   // e.g., "create", "read", "update", "delete", "manage"
  description String?
  roles       RolePermission[]
  createdAt   DateTime @default(now())

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  scope        String   @default("own") // "own" | "organization" | "geographic" | "all"
  conditions   Json?    // { district: "Warangal", state: "Telangana" } for geographic scope

  role         RoleDefinition @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission     @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id             String    @id @default(cuid())
  userId         String
  roleId         String
  organizationId String?
  assignedBy     String?
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           RoleDefinition @relation(fields: [roleId], references: [id], onDelete: Cascade)
  organization   Organization?  @relation(fields: [organizationId], references: [id])

  @@unique([userId, roleId])
  @@index([userId])
  @@map("user_roles")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  type      String   // "FPO" | "COMPANY" | "COOPERATIVE" | "GOVERNMENT"
  district  String?
  state     String?
  isActive  Boolean  @default(true)
  members   User[]
  userRoles UserRole[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("organizations")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String   // "create", "update", "delete", "login", "logout"
  resource   String   // "user", "booking", "payment", etc.
  resourceId String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── END RBAC ────────────────────────────────────────────

model Crop {
  id       String       @id
  name     String
  category CropCategory
  icon     String
  color    String
  unit     String

  prices          Price[]
  users           UserCrop[]
  priceHistories  PriceHistory[]
  priceAlerts     PriceAlert[]
  calendars       CropCalendar[]
  listings        Listing[]
  communityPosts  CommunityPost[]

  @@map("crops")
}

model Mandi {
  id          String  @id
  name        String
  district    String
  state       String
  distanceKm  Float
  latitude    Float
  longitude   Float
  activeCrops Int
  volume      String

  prices         Price[]
  users          UserMandi[]
  priceHistories PriceHistory[]
  priceAlerts    PriceAlert[]
  listings       Listing[]

  @@map("mandis")
}

model Price {
  id            String   @id @default(cuid())
  cropId        String
  mandiId       String
  minPrice      Decimal  @db.Decimal(10, 2)
  maxPrice      Decimal  @db.Decimal(10, 2)
  modalPrice    Decimal  @db.Decimal(10, 2)
  farmGatePrice Decimal  @db.Decimal(10, 2)
  dealerPrice   Decimal  @db.Decimal(10, 2)
  retailPrice   Decimal  @db.Decimal(10, 2)
  dealerMargin  Decimal  @db.Decimal(5, 2)
  change        Decimal  @db.Decimal(10, 2)
  changePercent Decimal  @db.Decimal(5, 2)
  volume        String
  unit          String   @default("quintal")
  updatedAt     DateTime @default(now())

  crop          Crop     @relation(fields: [cropId], references: [id])
  mandi         Mandi    @relation(fields: [mandiId], references: [id])

  @@map("prices")
}

model News {
  id        String       @id
  title     String
  summary   String
  category  NewsCategory
  date      String
  readTime  String
  createdAt DateTime     @default(now())

  @@map("news")
}

model DiseaseResult {
  id             String   @id @default(cuid())
  cropName       String
  diseaseName    String
  confidence     Float
  severity       String
  affectedArea   Float
  weatherNote    String?
  treatments     Json
  nearbyAdvisory String?
  createdAt      DateTime @default(now())

  @@map("disease_results")
}

model UserCrop {
  userId String
  cropId String

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  crop   Crop @relation(fields: [cropId], references: [id], onDelete: Cascade)

  @@id([userId, cropId])
  @@map("user_crops")
}

model UserMandi {
  userId  String
  mandiId String

  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  mandi   Mandi @relation(fields: [mandiId], references: [id], onDelete: Cascade)

  @@id([userId, mandiId])
  @@map("user_mandis")
}

model OtpVerification {
  id        String   @id @default(cuid())
  mobile    String
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([mobile, otp])
  @@map("otp_verifications")
}

model PriceHistory {
  id            String   @id @default(cuid())
  cropId        String
  mandiId       String
  minPrice      Decimal  @db.Decimal(10, 2)
  maxPrice      Decimal  @db.Decimal(10, 2)
  modalPrice    Decimal  @db.Decimal(10, 2)
  farmGatePrice Decimal  @db.Decimal(10, 2)
  dealerPrice   Decimal  @db.Decimal(10, 2)
  retailPrice   Decimal  @db.Decimal(10, 2)
  change        Decimal  @db.Decimal(10, 2) @default(0)
  changePercent Decimal  @db.Decimal(5, 2) @default(0)
  volume        String   @default("")
  source        String   @default("seed")
  date          DateTime
  createdAt     DateTime @default(now())

  crop  Crop  @relation(fields: [cropId], references: [id])
  mandi Mandi @relation(fields: [mandiId], references: [id])

  @@unique([cropId, mandiId, date])
  @@map("price_history")
}

model PriceAlert {
  id          String    @id @default(cuid())
  userId      String
  cropId      String
  mandiId     String?
  targetPrice Decimal  @db.Decimal(10, 2)
  direction   String    // "above" | "below"
  priceType   String    @default("mandi") // "mandi" | "farmGate" | "dealer" | "retail"
  isActive    Boolean   @default(true)
  triggeredAt DateTime?
  createdAt   DateTime  @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  crop  Crop   @relation(fields: [cropId], references: [id])
  mandi Mandi? @relation(fields: [mandiId], references: [id])

  @@map("price_alerts")
}

model CropCalendar {
  id         String @id @default(cuid())
  cropId     String
  region     String // "telangana_kharif" | "telangana_rabi"
  activities Json   // Array of { week: number, activity: string, description: string, inputs?: string }

  crop Crop @relation(fields: [cropId], references: [id])

  @@unique([cropId, region])
  @@map("crop_calendars")
}

model UserCalendarTask {
  id           String    @id @default(cuid())
  userId       String
  cropId       String
  activity     String
  description  String    @default("")
  week         Int
  scheduledFor DateTime
  isCompleted  Boolean   @default(false)
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_calendar_tasks")
}

model Listing {
  id           String    @id @default(cuid())
  userId       String
  cropId       String
  type         String    // "sell" | "buy"
  quantity     Float
  unit         String
  pricePerUnit Float?
  description  String?
  mandiId      String?
  location     String?
  expiresAt    DateTime
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  category     String    @default("crop")  // "crop"|"machinery"|"resource"|"tool"|"seed"|"labor"|"irrigation"|"animal"|"postharvest"|"growth_regulator"
  itemId       String?   // References InventoryItem.id (optional, for non-crop listings)
  itemName     String?   // Free-text item name (for items not in inventory)
  listingType  String    @default("sell")  // "sell"|"buy"|"rent"|"exchange"
  images       String[]
  phone        String?
  condition    String?   // "new"|"used"|"half_used"
  rentalBasis  String?   // "per_day"|"per_hour"|"per_acre"|null

  user      User      @relation(fields: [userId], references: [id])
  crop      Crop      @relation(fields: [cropId], references: [id])
  mandi     Mandi?    @relation(fields: [mandiId], references: [id])
  inquiries Inquiry[]

  @@map("listings")
}

model Inquiry {
  id         String   @id @default(cuid())
  listingId  String
  fromUserId String
  message    String
  phone      String?
  createdAt  DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  fromUser User   @relation("inquiriesSent", fields: [fromUserId], references: [id])

  @@map("inquiries")
}

model InventoryCategory {
  id          String  @id
  names       Json    // { "en": "Machinery", "te": "యంత్రాలు", "hi": "मशीनरी" }
  icon        String
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  items InventoryItem[]

  @@map("inventory_categories")
}

model InventoryItem {
  id            String  @id
  categoryId    String
  names         Json    // { "en": "Tractor", "te": "ట్రాక్టర్", "hi": "ट्रैक्टर" }
  descriptions  Json?   // { "en": "...", "te": "...", "hi": "..." }
  defaultUnit   String  // "per_day", "per_kg", "per_liter", "per_bag", "per_acre", "per_hour", "piece"
  unitLabels    Json    // { "en": "per day", "te": "రోజుకు", "hi": "प्रति दिन" }
  transactionTypes String[] // ["sell", "buy", "rent", "exchange"]
  tags          String[]    // ["organic", "chemical", "bt", "hybrid", etc.]
  brand         String?
  isActive      Boolean @default(true)
  sortOrder     Int     @default(0)

  category InventoryCategory @relation(fields: [categoryId], references: [id])

  @@map("inventory_items")
}

model CommunityPost {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "question" | "success_story" | "tip" | "pest_help"
  title     String
  content   String
  images    String[]
  cropId    String?
  location  String?
  tags      String[]
  upvotes   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User              @relation(fields: [userId], references: [id])
  crop     Crop?             @relation(fields: [cropId], references: [id])
  comments CommunityComment[]

  @@map("community_posts")
}

model CommunityComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  images    String[]
  isAnswer  Boolean  @default(false)
  upvotes   Int      @default(0)
  createdAt DateTime @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id])

  @@map("community_comments")
}

// ─── SERVICE MARKETPLACE (Phase 1) ───────────────────────

enum ProviderType {
  MACHINERY_OWNER
  INPUT_DEALER
  TRANSPORTER
  LABOR_INDIVIDUAL
  LABOR_TEAM_LEADER
  LIVESTOCK_DEALER
  DRONE_OPERATOR
  PROFESSIONAL
}

enum KYCStatus {
  NOT_STARTED
  SUBMITTED
  UNDER_REVIEW
  VERIFIED
  REJECTED
}

enum PricingType {
  FIXED
  NEGOTIABLE
  BID_BASED
}

enum PricingUnit {
  PER_HOUR
  PER_DAY
  PER_ACRE
  PER_UNIT
  PER_KG
  PER_QUINTAL
  PER_TRIP
  PER_WORKER_DAY
  FIXED
}

enum BookingType {
  SLOT
  DAY
  MULTI_DAY
  ON_DEMAND
}

model ServiceProvider {
  id              String       @id @default(cuid())
  userId          String       @unique
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            ProviderType
  businessName    String?
  description     String?
  profilePhoto    String?
  serviceRadius   Int          @default(25) // km
  languages       String[]     @default(["te", "hi", "en"])
  experience      Int?         // years

  // Location (for PostGIS queries)
  latitude        Float?
  longitude       Float?
  address         String?
  village         String?
  district        String?
  state           String?

  // KYC
  kycStatus       KYCStatus    @default(NOT_STARTED)
  aadhaarNumber   String?      // Encrypted at rest
  panNumber       String?
  gstNumber       String?
  bankAccountNo   String?      // Encrypted
  bankIfsc        String?
  kycDocuments    String[]     // S3 URLs for uploaded docs
  kycSubmittedAt  DateTime?
  kycVerifiedAt   DateTime?
  kycReviewNote   String?

  // Stats
  rating          Decimal      @db.Decimal(3, 2) @default(0)
  totalBookings   Int          @default(0)
  completionRate  Decimal      @db.Decimal(5, 2) @default(100)
  responseTime    Int?         // avg minutes to respond
  isVerified      Boolean      @default(false)
  isActive        Boolean      @default(true)

  listings          ServiceListing[]
  bookings          Booking[]
  availabilitySlots AvailabilitySlot[]
  chatConversations ChatConversation[] @relation("ProviderChats")
  payouts           Payout[]
  taxProfile        TaxProfile?
  laborTeams        LaborTeam[]
  bids              Bid[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([latitude, longitude])
  @@index([type])
  @@index([district, state])
  @@index([kycStatus])
  @@map("service_providers")
}

model ServiceCategory {
  id              String   @id @default(cuid())
  name            Json     // { en: "Machinery", te: "యంత్రాలు", hi: "मशीनरी" }
  slug            String   @unique
  description     Json?    // multilingual description
  icon            String   @default("🔧")
  parentId        String?
  parent          ServiceCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children        ServiceCategory[] @relation("CategoryHierarchy")
  sortOrder       Int      @default(0)
  bookingType     BookingType @default(DAY)
  defaultUnit     PricingUnit @default(PER_DAY)
  requiresLicense Boolean  @default(false)
  isActive        Boolean  @default(true)

  listings        ServiceListing[]
  createdAt       DateTime @default(now())

  @@index([parentId])
  @@map("service_categories")
}

// ─── BOOKING SYSTEM (Phase 2) ────────────────────────────

model Booking {
  id                String   @id @default(cuid())
  bookingNumber     String   @unique // "KC-BK-20260415-0001"

  // Parties
  farmerId          String
  providerId        String
  serviceListingId  String

  // Booking type (inherited from category)
  bookingType       String   // "SLOT" | "DAY" | "MULTI_DAY" | "ON_DEMAND"

  // Schedule
  startDate         DateTime
  endDate           DateTime
  slotType          String?  // "MORNING" | "AFTERNOON" | "FULL_DAY"

  // Location
  farmLocation      Json     // { lat, lng, village, mandal, district, state, address }
  farmSize          Float?   // Acres (for per-acre pricing)
  cropType          String?

  // Pricing
  basePrice         Float
  platformFee       Float
  gstAmount         Float
  totalAmount       Float
  advanceAmount     Float?
  balanceAmount     Float?

  // State Machine
  status            String   @default("PENDING")
  statusHistory     Json[]   // [{ status, timestamp, changedBy, reason }]

  // Cancellation
  cancelledBy       String?  // "FARMER" | "PROVIDER" | "SYSTEM"
  cancellationReason String?
  cancellationFee   Float?

  // Weather
  weatherHoldReason  String?
  originalStartDate  DateTime?
  rescheduledFrom    String?

  // Completion
  completedAt        DateTime?
  farmerConfirmed    Boolean  @default(false)
  providerConfirmed  Boolean  @default(false)
  autoConfirmedAt    DateTime?

  // Recurring
  recurringBookingId String?

  // Notes
  farmerNotes        String?
  providerNotes      String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  farmer             User              @relation("FarmerBookings", fields: [farmerId], references: [id])
  provider           ServiceProvider   @relation(fields: [providerId], references: [id])
  serviceListing     ServiceListing    @relation(fields: [serviceListingId], references: [id])
  recurringBooking   RecurringBooking? @relation(fields: [recurringBookingId], references: [id])
  chatConversation   ChatConversation?
  payments           Payment[]

  @@index([farmerId, status])
  @@index([providerId, status])
  @@index([startDate, endDate])
  @@index([status, createdAt])
  @@map("bookings")
}

model AvailabilitySlot {
  id               String   @id @default(cuid())
  providerId       String
  serviceListingId String?

  date             DateTime @db.Date
  slotType         String   // "MORNING" | "AFTERNOON" | "FULL_DAY"
  isAvailable      Boolean  @default(true)
  isBlocked        Boolean  @default(false)
  blockReason      String?  // "TRANSIT" | "MAINTENANCE" | "PERSONAL" | "BOOKED"

  transitFromBookingId      String?
  transitHours              Int?
  maintenanceAfterBookingId String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  provider         ServiceProvider @relation(fields: [providerId], references: [id])

  @@unique([providerId, date, slotType, serviceListingId])
  @@index([providerId, date, isAvailable])
  @@map("availability_slots")
}

model RecurringBooking {
  id               String   @id @default(cuid())
  farmerId         String
  providerId       String
  serviceListingId String

  frequency        String   // "WEEKLY" | "BIWEEKLY" | "MONTHLY"
  dayOfWeek        Int?     // 0-6
  dayOfMonth       Int?     // 1-31
  slotType         String?

  startDate        DateTime
  endDate          DateTime?

  isActive         Boolean  @default(true)
  nextOccurrence   DateTime?
  totalGenerated   Int      @default(0)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  bookings         Booking[]

  @@map("recurring_bookings")
}

// ─── CHAT SYSTEM (Phase 2) ──────────────────────────────

model ChatConversation {
  id              String   @id @default(cuid())
  bookingId       String?  @unique

  farmerId        String
  providerId      String

  lastMessageAt   DateTime?
  farmerUnread    Int      @default(0)
  providerUnread  Int      @default(0)
  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  booking         Booking?          @relation(fields: [bookingId], references: [id])
  farmer          User              @relation("FarmerChats", fields: [farmerId], references: [id])
  provider        ServiceProvider   @relation("ProviderChats", fields: [providerId], references: [id])
  messages        ChatMessage[]

  @@index([farmerId, lastMessageAt])
  @@index([providerId, lastMessageAt])
  @@map("chat_conversations")
}

model ChatMessage {
  id              String   @id @default(cuid())
  conversationId  String
  senderId        String

  type            String   @default("TEXT") // "TEXT" | "IMAGE" | "LOCATION" | "BOOKING_UPDATE" | "VOICE"
  content         String
  metadata        Json?

  isRead          Boolean  @default(false)
  readAt          DateTime?
  isDeleted       Boolean  @default(false)

  createdAt       DateTime @default(now())

  conversation    ChatConversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId, createdAt])
  @@map("chat_messages")
}

// ─── NOTIFICATION SYSTEM (Phase 2) ──────────────────────

model Notification {
  id              String   @id @default(cuid())
  userId          String

  type            String   // "BOOKING_CREATED" | "BOOKING_CONFIRMED" | etc.
  title           Json     // { "en": "...", "te": "...", "hi": "..." }
  body            Json     // { "en": "...", "te": "...", "hi": "..." }
  data            Json?    // { bookingId, screen, params }

  channel         String[] // ["PUSH", "SMS", "IN_APP"]

  isRead          Boolean  @default(false)
  readAt          DateTime?

  pushSent        Boolean  @default(false)
  pushSentAt      DateTime?
  smsSent         Boolean  @default(false)
  smsSentAt       DateTime?

  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

model DeviceToken {
  id              String   @id @default(cuid())
  userId          String
  token           String   @unique
  platform        String   // "ANDROID" | "IOS" | "WEB"
  isActive        Boolean  @default(true)
  lastUsedAt      DateTime @default(now())

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])

  @@index([userId, isActive])
  @@map("device_tokens")
}

model ServiceListing {
  id                  String   @id @default(cuid())
  providerId          String
  provider            ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  categoryId          String
  category            ServiceCategory @relation(fields: [categoryId], references: [id])

  title               Json     // { en: "Tractor for hire", te: "అద్దెకు ట్రాక్టర్" }
  description         Json?    // multilingual
  images              String[] // S3 URLs
  pricingType         PricingType @default(FIXED)
  pricePerUnit        Decimal  @db.Decimal(10, 2)
  unit                PricingUnit @default(PER_DAY)
  minBookingDuration  Int      @default(1) // minimum booking in units

  // Equipment details (for machinery/drones)
  equipmentMake       String?
  equipmentModel      String?
  equipmentYear       Int?
  equipmentHP         Int?     // horsepower
  equipmentDetails    Json?    // flexible extra fields

  // Availability
  isActive            Boolean  @default(true)
  isPaused            Boolean  @default(false)
  seasonalAvailable   String[] // ["kharif", "rabi", "summer"]

  bookings            Booking[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([providerId])
  @@index([categoryId])
  @@index([isActive, isPaused])
  @@map("service_listings")
}

// ─── PAYMENT SYSTEM (Phase 3) ────────────────────────────

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  UPI
  CARD
  NET_BANKING
  WALLET
  CASH
  UPI_ADVANCE_CASH_BALANCE
}

enum PaymentFlowType {
  FULL_PREPAY
  ADVANCE_BALANCE
  POST_PAY
  CASH_SPLIT
}

enum EscrowStatus {
  NOT_APPLICABLE
  HELD
  RELEASED
  REFUNDED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Payment {
  id                  String   @id @default(cuid())
  bookingId           String
  payerId             String   // farmer userId
  payeeProviderId     String   // service provider id

  // Razorpay
  razorpayOrderId     String?  @unique
  razorpayPaymentId   String?  @unique
  razorpaySignature   String?

  // Amounts
  amount              Decimal  @db.Decimal(15, 4)
  currency            String   @default("INR")
  platformFee         Decimal  @db.Decimal(15, 4) @default(0)
  gstOnFee            Decimal  @db.Decimal(15, 4) @default(0) // 18% GST on platform fee
  tdsAmount           Decimal  @db.Decimal(15, 4) @default(0) // Section 194-O

  // Flow & Status
  flowType            PaymentFlowType @default(FULL_PREPAY)
  paymentType         String   @default("FULL") // "FULL" | "ADVANCE" | "BALANCE" | "REFUND"
  method              PaymentMethod?
  status              PaymentStatus @default(PENDING)

  // Escrow
  escrowStatus        EscrowStatus @default(NOT_APPLICABLE)
  escrowReleasedAt    DateTime?
  escrowReleaseJobId  String?  // BullMQ delayed job ID for auto-release

  // Refund
  refundAmount        Decimal? @db.Decimal(15, 4)
  refundReason        String?
  refundedAt          DateTime?
  razorpayRefundId    String?

  // Metadata
  description         String?
  metadata            Json?
  failureReason       String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  booking             Booking  @relation(fields: [bookingId], references: [id])
  invoice             Invoice?

  @@index([bookingId])
  @@index([payerId])
  @@index([payeeProviderId])
  @@index([razorpayOrderId])
  @@index([status])
  @@map("payments")
}

model Wallet {
  id            String   @id @default(cuid())
  userId        String   @unique
  balance       Decimal  @db.Decimal(15, 4) @default(0)
  currency      String   @default("INR")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transactions  WalletTransaction[]
  user          User     @relation(fields: [userId], references: [id])

  @@map("wallets")
}

model WalletTransaction {
  id              String   @id @default(cuid())
  walletId        String
  amount          Decimal  @db.Decimal(15, 4)
  type            String   // "CREDIT" | "DEBIT"
  source          String   // "PAYMENT" | "REFUND" | "CASHBACK" | "PAYOUT" | "TOPUP" | "WITHDRAWAL"
  referenceId     String?  // paymentId, payoutId, etc.
  description     String?
  balanceBefore   Decimal  @db.Decimal(15, 4)
  balanceAfter    Decimal  @db.Decimal(15, 4)
  createdAt       DateTime @default(now())

  wallet          Wallet   @relation(fields: [walletId], references: [id])

  @@index([walletId, createdAt])
  @@map("wallet_transactions")
}

model Payout {
  id                  String   @id @default(cuid())
  providerId          String
  amount              Decimal  @db.Decimal(15, 4)
  currency            String   @default("INR")
  status              PayoutStatus @default(PENDING)

  // Razorpay payout
  razorpayPayoutId    String?  @unique
  razorpayContactId   String?
  razorpayFundAccountId String?

  // Settlement period
  periodStart         DateTime
  periodEnd           DateTime
  bookingCount        Int      @default(0)
  grossAmount         Decimal  @db.Decimal(15, 4) @default(0)
  commissionTotal     Decimal  @db.Decimal(15, 4) @default(0)
  tdsTotal            Decimal  @db.Decimal(15, 4) @default(0)
  netAmount           Decimal  @db.Decimal(15, 4) @default(0)

  // Bank details snapshot
  bankAccountNo       String?
  bankIfsc            String?
  bankName            String?

  processedAt         DateTime?
  failureReason       String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  provider            ServiceProvider @relation(fields: [providerId], references: [id])

  @@index([providerId, status])
  @@index([periodStart, periodEnd])
  @@map("payouts")
}

model Invoice {
  id              String   @id @default(cuid())
  paymentId       String   @unique
  invoiceNumber   String   @unique // "KC-INV-20260415-0001"
  type            String   @default("BOOKING") // "BOOKING" | "SUBSCRIPTION" | "PAYOUT"

  // Parties
  farmerName      String?
  farmerMobile    String?
  farmerAddress   String?
  providerName    String?
  providerGstin   String?

  // Line items
  lineItems       Json     // [{ description, qty, rate, amount }]
  subtotal        Decimal  @db.Decimal(15, 4)
  platformFee     Decimal  @db.Decimal(15, 4) @default(0)
  gst             Decimal  @db.Decimal(15, 4) @default(0)
  total           Decimal  @db.Decimal(15, 4)

  pdfUrl          String?  // S3 URL to generated PDF

  createdAt       DateTime @default(now())

  payment         Payment  @relation(fields: [paymentId], references: [id])

  @@index([invoiceNumber])
  @@map("invoices")
}

model TaxProfile {
  id              String   @id @default(cuid())
  providerId      String   @unique
  panNumber       String?  // Validated PAN
  panVerified     Boolean  @default(false)
  gstNumber       String?
  gstVerified     Boolean  @default(false)

  // TDS tracking (Section 194-O)
  financialYear   String   @default("2026-27") // "YYYY-YY"
  totalPayouts    Decimal  @db.Decimal(15, 4) @default(0)
  totalTdsDeducted Decimal @db.Decimal(15, 4) @default(0)
  tdsThreshold    Decimal  @db.Decimal(15, 4) @default(500000) // INR 5L

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  provider        ServiceProvider @relation(fields: [providerId], references: [id])

  @@index([financialYear])
  @@map("tax_profiles")
}

// ─── LABOR MARKETPLACE (Phase 4) ────────────────────────

model LaborTeam {
  id                  String   @id @default(cuid())
  leaderId            String

  name                Json     // { "en": "Raju's Harvesting Team", "te": "రాజు కోత జట్టు" }
  description         Json?

  // Skills (aggregated from members)
  skills              String[] // ["weeding", "transplanting", "harvesting"]
  primarySkill        String

  // Capacity
  maxMembers          Int      @default(20)
  activeMembers       Int      @default(0)

  // Location
  baseLocation        Json     // { lat, lng, village, mandal, district, state }
  serviceRadius       Int      @default(30) // km

  // Rates
  dailyRatePerWorker  Float
  minimumWorkers      Int      @default(1)

  // Stats
  rating              Float    @default(0)
  totalJobs           Int      @default(0)
  completionRate      Float    @default(0)

  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  leader              ServiceProvider @relation(fields: [leaderId], references: [id])
  members             TeamMember[]
  bids                Bid[]

  @@index([leaderId])
  @@map("labor_teams")
}

model TeamMember {
  id                  String   @id @default(cuid())
  teamId              String

  // Worker profile
  name                String
  phone               String
  aadhaarLast4        String?
  photo               String?

  // Skills
  skills              String[] // ["weeding", "transplanting", "harvesting"]
  experience          Int?     // Years
  preferredCrops      String[] // ["cotton", "rice", "chilli"]

  // Availability
  isAvailable         Boolean  @default(true)
  unavailableFrom     DateTime?
  unavailableTo       DateTime?
  unavailableReason   String?

  // Rate
  dailyRate           Float    // INR per day

  // Bank details (for direct payment)
  bankAccountNumber   String?  // Encrypted
  bankIfsc            String?
  bankAccountName     String?
  upiId               String?

  // Stats
  daysWorked          Int      @default(0)
  rating              Float    @default(0)
  noShowCount         Int      @default(0)

  isActive            Boolean  @default(true)
  joinedAt            DateTime @default(now())

  team                LaborTeam    @relation(fields: [teamId], references: [id])
  attendance          Attendance[]

  @@index([teamId, isAvailable])
  @@map("team_members")
}

model JobPosting {
  id                      String   @id @default(cuid())
  farmerId                String

  // Job details
  title                   Json     // { "en": "Need 5 laborers for cotton picking", "te": "..." }
  description             Json?

  // Requirements
  skillRequired           String   // "harvesting" | "weeding" | "transplanting" | etc.
  workersNeeded           Int

  // Schedule
  startDate               DateTime
  endDate                 DateTime
  daysNeeded              Int
  slotType                String   @default("FULL_DAY") // "MORNING" | "AFTERNOON" | "FULL_DAY"

  // Location
  farmLocation            Json     // { lat, lng, village, mandal, district, state }
  farmSize                Float?   // Acres
  cropType                String?

  // Budget
  budgetPerWorkerPerDay   Float?
  totalBudget             Float?

  // Status
  status                  String   @default("OPEN")
  // "OPEN" | "BIDDING" | "ASSIGNED" | "IN_PROGRESS" | "COMPLETED" | "CANCELLED"

  // Assignment
  assignedBidId           String?  @unique
  assignedTeamId          String?

  // Metadata
  viewCount               Int      @default(0)
  bidCount                Int      @default(0)

  expiresAt               DateTime

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  farmer                  User     @relation(fields: [farmerId], references: [id])
  assignedBid             Bid?     @relation("AssignedBid", fields: [assignedBidId], references: [id])
  bids                    Bid[]    @relation("JobBids")

  @@index([status, skillRequired])
  @@index([farmerId, status])
  @@map("job_postings")
}

model Bid {
  id                      String   @id @default(cuid())
  jobPostingId            String
  teamId                  String?
  providerId              String

  // Bid details
  ratePerWorkerPerDay     Float
  totalAmount             Float
  workersOffered          Int
  message                 Json?    // { "en": "We have experienced cotton pickers...", "te": "..." }

  // Status
  status                  String   @default("PENDING")
  // "PENDING" | "ACCEPTED" | "REJECTED" | "WITHDRAWN" | "EXPIRED"
  rejectionReason         String?

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  jobPosting              JobPosting      @relation("JobBids", fields: [jobPostingId], references: [id])
  team                    LaborTeam?      @relation(fields: [teamId], references: [id])
  provider                ServiceProvider @relation(fields: [providerId], references: [id])
  assignedTo              JobPosting?     @relation("AssignedBid")

  @@unique([jobPostingId, providerId])
  @@index([jobPostingId, status])
  @@map("bids")
}

model Attendance {
  id                  String   @id @default(cuid())
  bookingId           String
  teamMemberId        String?
  workerId            String

  date                DateTime @db.Date

  // Check-in
  checkInTime         DateTime?
  checkInLat          Float?
  checkInLng          Float?
  checkInDistance      Float?   // Distance from farm in meters
  checkInQrCode       String?
  checkInPhoto        String?
  checkInVerified     Boolean  @default(false)

  // Check-out
  checkOutTime        DateTime?
  checkOutLat         Float?
  checkOutLng         Float?
  checkOutDistance     Float?
  checkOutQrCode      String?
  checkOutPhoto       String?
  checkOutVerified    Boolean  @default(false)

  // Hours
  hoursWorked         Float?
  overtimeHours       Float?
  breakMinutes        Int?

  // Status
  status              String   @default("ABSENT")
  // "PRESENT" | "ABSENT" | "HALF_DAY" | "LATE" | "SUBSTITUTE" | "NO_SHOW"

  // Substitute
  isSubstitute        Boolean  @default(false)
  substitutedFor      String?

  // Payment
  dailyAmount         Float?
  overtimeAmount      Float?
  deductions          Float?
  netAmount           Float?
  paymentStatus       String   @default("PENDING") // "PENDING" | "PROCESSED" | "PAID"

  notes               String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  teamMember          TeamMember? @relation(fields: [teamMemberId], references: [id])

  @@unique([bookingId, workerId, date])
  @@index([bookingId, date])
  @@index([teamMemberId, date])
  @@map("attendance")
}
