generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

enum Role {
  FARMER
  TRADER
  DEALER
  CORPORATE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum CropCategory {
  cereal
  pulse
  cash
  spice
  vegetable
}

enum NewsCategory {
  market
  policy
  weather
  advisory
}

model User {
  id             String      @id @default(cuid())
  mobile         String      @unique
  aadhaar        String?
  firstName      String?
  surname        String?
  role           Role?
  houseNo        String?
  street         String?
  village        String?
  post           String?
  mandal         String?
  district       String?
  state          String?
  country        String?     @default("India")
  dob            DateTime?
  gender         Gender?
  language       String?     @default("en")
  updatesConsent Boolean     @default(false)
  profilePhoto   String?
  lastActive     DateTime    @default(now())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  crops              UserCrop[]
  mandis             UserMandi[]
  priceAlerts        PriceAlert[]
  calendarTasks      UserCalendarTask[]
  listings           Listing[]
  inquiriesSent      Inquiry[] @relation("inquiriesSent")
  communityPosts     CommunityPost[]
  communityComments  CommunityComment[]
  refreshTokens      RefreshToken[]
  userRoles          UserRole[]
  auditLogs          AuditLog[]
  serviceProvider    ServiceProvider?
  organizationId     String?
  organization       Organization? @relation(fields: [organizationId], references: [id])

  @@map("users")
}

model RefreshToken {
  id            String   @id @default(cuid())
  token         String   @unique
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceInfo    String?
  ipAddress     String?
  expiresAt     DateTime
  revoked       Boolean  @default(false)
  revokedAt     DateTime?
  replacedById  String?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ─── RBAC SYSTEM ─────────────────────────────────────────

model RoleDefinition {
  id           String   @id @default(cuid())
  name         String   @unique // SUPER_ADMIN, FARMER, VENDOR, etc.
  displayName  Json     // { en: "Farmer", te: "రైతు", hi: "किसान" }
  description  String?
  isSystem     Boolean  @default(true) // System roles can't be deleted
  parentId     String?
  parent       RoleDefinition?  @relation("RoleHierarchy", fields: [parentId], references: [id])
  children     RoleDefinition[] @relation("RoleHierarchy")
  permissions  RolePermission[]
  userRoles    UserRole[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("role_definitions")
}

model Permission {
  id          String   @id @default(cuid())
  resource    String   // e.g., "bookings", "services", "users", "payments"
  action      String   // e.g., "create", "read", "update", "delete", "manage"
  description String?
  roles       RolePermission[]
  createdAt   DateTime @default(now())

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  scope        String   @default("own") // "own" | "organization" | "geographic" | "all"
  conditions   Json?    // { district: "Warangal", state: "Telangana" } for geographic scope

  role         RoleDefinition @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission     @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id             String    @id @default(cuid())
  userId         String
  roleId         String
  organizationId String?
  assignedBy     String?
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           RoleDefinition @relation(fields: [roleId], references: [id], onDelete: Cascade)
  organization   Organization?  @relation(fields: [organizationId], references: [id])

  @@unique([userId, roleId])
  @@index([userId])
  @@map("user_roles")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  type      String   // "FPO" | "COMPANY" | "COOPERATIVE" | "GOVERNMENT"
  district  String?
  state     String?
  isActive  Boolean  @default(true)
  members   User[]
  userRoles UserRole[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("organizations")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String   // "create", "update", "delete", "login", "logout"
  resource   String   // "user", "booking", "payment", etc.
  resourceId String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── END RBAC ────────────────────────────────────────────

model Crop {
  id       String       @id
  name     String
  category CropCategory
  icon     String
  color    String
  unit     String

  prices          Price[]
  users           UserCrop[]
  priceHistories  PriceHistory[]
  priceAlerts     PriceAlert[]
  calendars       CropCalendar[]
  listings        Listing[]
  communityPosts  CommunityPost[]

  @@map("crops")
}

model Mandi {
  id          String  @id
  name        String
  district    String
  state       String
  distanceKm  Float
  latitude    Float
  longitude   Float
  activeCrops Int
  volume      String

  prices         Price[]
  users          UserMandi[]
  priceHistories PriceHistory[]
  priceAlerts    PriceAlert[]
  listings       Listing[]

  @@map("mandis")
}

model Price {
  id            String   @id @default(cuid())
  cropId        String
  mandiId       String
  minPrice      Decimal  @db.Decimal(10, 2)
  maxPrice      Decimal  @db.Decimal(10, 2)
  modalPrice    Decimal  @db.Decimal(10, 2)
  farmGatePrice Decimal  @db.Decimal(10, 2)
  dealerPrice   Decimal  @db.Decimal(10, 2)
  retailPrice   Decimal  @db.Decimal(10, 2)
  dealerMargin  Decimal  @db.Decimal(5, 2)
  change        Decimal  @db.Decimal(10, 2)
  changePercent Decimal  @db.Decimal(5, 2)
  volume        String
  unit          String   @default("quintal")
  updatedAt     DateTime @default(now())

  crop          Crop     @relation(fields: [cropId], references: [id])
  mandi         Mandi    @relation(fields: [mandiId], references: [id])

  @@map("prices")
}

model News {
  id        String       @id
  title     String
  summary   String
  category  NewsCategory
  date      String
  readTime  String
  createdAt DateTime     @default(now())

  @@map("news")
}

model DiseaseResult {
  id             String   @id @default(cuid())
  cropName       String
  diseaseName    String
  confidence     Float
  severity       String
  affectedArea   Float
  weatherNote    String?
  treatments     Json
  nearbyAdvisory String?
  createdAt      DateTime @default(now())

  @@map("disease_results")
}

model UserCrop {
  userId String
  cropId String

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  crop   Crop @relation(fields: [cropId], references: [id], onDelete: Cascade)

  @@id([userId, cropId])
  @@map("user_crops")
}

model UserMandi {
  userId  String
  mandiId String

  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  mandi   Mandi @relation(fields: [mandiId], references: [id], onDelete: Cascade)

  @@id([userId, mandiId])
  @@map("user_mandis")
}

model OtpVerification {
  id        String   @id @default(cuid())
  mobile    String
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([mobile, otp])
  @@map("otp_verifications")
}

model PriceHistory {
  id            String   @id @default(cuid())
  cropId        String
  mandiId       String
  minPrice      Decimal  @db.Decimal(10, 2)
  maxPrice      Decimal  @db.Decimal(10, 2)
  modalPrice    Decimal  @db.Decimal(10, 2)
  farmGatePrice Decimal  @db.Decimal(10, 2)
  dealerPrice   Decimal  @db.Decimal(10, 2)
  retailPrice   Decimal  @db.Decimal(10, 2)
  change        Decimal  @db.Decimal(10, 2) @default(0)
  changePercent Decimal  @db.Decimal(5, 2) @default(0)
  volume        String   @default("")
  source        String   @default("seed")
  date          DateTime
  createdAt     DateTime @default(now())

  crop  Crop  @relation(fields: [cropId], references: [id])
  mandi Mandi @relation(fields: [mandiId], references: [id])

  @@unique([cropId, mandiId, date])
  @@map("price_history")
}

model PriceAlert {
  id          String    @id @default(cuid())
  userId      String
  cropId      String
  mandiId     String?
  targetPrice Decimal  @db.Decimal(10, 2)
  direction   String    // "above" | "below"
  priceType   String    @default("mandi") // "mandi" | "farmGate" | "dealer" | "retail"
  isActive    Boolean   @default(true)
  triggeredAt DateTime?
  createdAt   DateTime  @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  crop  Crop   @relation(fields: [cropId], references: [id])
  mandi Mandi? @relation(fields: [mandiId], references: [id])

  @@map("price_alerts")
}

model CropCalendar {
  id         String @id @default(cuid())
  cropId     String
  region     String // "telangana_kharif" | "telangana_rabi"
  activities Json   // Array of { week: number, activity: string, description: string, inputs?: string }

  crop Crop @relation(fields: [cropId], references: [id])

  @@unique([cropId, region])
  @@map("crop_calendars")
}

model UserCalendarTask {
  id           String    @id @default(cuid())
  userId       String
  cropId       String
  activity     String
  description  String    @default("")
  week         Int
  scheduledFor DateTime
  isCompleted  Boolean   @default(false)
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_calendar_tasks")
}

model Listing {
  id           String    @id @default(cuid())
  userId       String
  cropId       String
  type         String    // "sell" | "buy"
  quantity     Float
  unit         String
  pricePerUnit Float?
  description  String?
  mandiId      String?
  location     String?
  expiresAt    DateTime
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  category     String    @default("crop")  // "crop"|"machinery"|"resource"|"tool"|"seed"|"labor"|"irrigation"|"animal"|"postharvest"|"growth_regulator"
  itemId       String?   // References InventoryItem.id (optional, for non-crop listings)
  itemName     String?   // Free-text item name (for items not in inventory)
  listingType  String    @default("sell")  // "sell"|"buy"|"rent"|"exchange"
  images       String[]
  phone        String?
  condition    String?   // "new"|"used"|"half_used"
  rentalBasis  String?   // "per_day"|"per_hour"|"per_acre"|null

  user      User      @relation(fields: [userId], references: [id])
  crop      Crop      @relation(fields: [cropId], references: [id])
  mandi     Mandi?    @relation(fields: [mandiId], references: [id])
  inquiries Inquiry[]

  @@map("listings")
}

model Inquiry {
  id         String   @id @default(cuid())
  listingId  String
  fromUserId String
  message    String
  phone      String?
  createdAt  DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  fromUser User   @relation("inquiriesSent", fields: [fromUserId], references: [id])

  @@map("inquiries")
}

model InventoryCategory {
  id          String  @id
  names       Json    // { "en": "Machinery", "te": "యంత్రాలు", "hi": "मशीनरी" }
  icon        String
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  items InventoryItem[]

  @@map("inventory_categories")
}

model InventoryItem {
  id            String  @id
  categoryId    String
  names         Json    // { "en": "Tractor", "te": "ట్రాక్టర్", "hi": "ट्रैक्टर" }
  descriptions  Json?   // { "en": "...", "te": "...", "hi": "..." }
  defaultUnit   String  // "per_day", "per_kg", "per_liter", "per_bag", "per_acre", "per_hour", "piece"
  unitLabels    Json    // { "en": "per day", "te": "రోజుకు", "hi": "प्रति दिन" }
  transactionTypes String[] // ["sell", "buy", "rent", "exchange"]
  tags          String[]    // ["organic", "chemical", "bt", "hybrid", etc.]
  brand         String?
  isActive      Boolean @default(true)
  sortOrder     Int     @default(0)

  category InventoryCategory @relation(fields: [categoryId], references: [id])

  @@map("inventory_items")
}

model CommunityPost {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "question" | "success_story" | "tip" | "pest_help"
  title     String
  content   String
  images    String[]
  cropId    String?
  location  String?
  tags      String[]
  upvotes   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User              @relation(fields: [userId], references: [id])
  crop     Crop?             @relation(fields: [cropId], references: [id])
  comments CommunityComment[]

  @@map("community_posts")
}

model CommunityComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  images    String[]
  isAnswer  Boolean  @default(false)
  upvotes   Int      @default(0)
  createdAt DateTime @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id])

  @@map("community_comments")
}

// ─── SERVICE MARKETPLACE (Phase 1) ───────────────────────

enum ProviderType {
  MACHINERY_OWNER
  INPUT_DEALER
  TRANSPORTER
  LABOR_INDIVIDUAL
  LABOR_TEAM_LEADER
  LIVESTOCK_DEALER
  DRONE_OPERATOR
  PROFESSIONAL
}

enum KYCStatus {
  NOT_STARTED
  SUBMITTED
  UNDER_REVIEW
  VERIFIED
  REJECTED
}

enum PricingType {
  FIXED
  NEGOTIABLE
  BID_BASED
}

enum PricingUnit {
  PER_HOUR
  PER_DAY
  PER_ACRE
  PER_UNIT
  PER_KG
  PER_QUINTAL
  PER_TRIP
  PER_WORKER_DAY
  FIXED
}

enum BookingType {
  SLOT
  DAY
  MULTI_DAY
  ON_DEMAND
}

model ServiceProvider {
  id              String       @id @default(cuid())
  userId          String       @unique
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            ProviderType
  businessName    String?
  description     String?
  profilePhoto    String?
  serviceRadius   Int          @default(25) // km
  languages       String[]     @default(["te", "hi", "en"])
  experience      Int?         // years

  // Location (for PostGIS queries)
  latitude        Float?
  longitude       Float?
  address         String?
  village         String?
  district        String?
  state           String?

  // KYC
  kycStatus       KYCStatus    @default(NOT_STARTED)
  aadhaarNumber   String?      // Encrypted at rest
  panNumber       String?
  gstNumber       String?
  bankAccountNo   String?      // Encrypted
  bankIfsc        String?
  kycDocuments    String[]     // S3 URLs for uploaded docs
  kycSubmittedAt  DateTime?
  kycVerifiedAt   DateTime?
  kycReviewNote   String?

  // Stats
  rating          Decimal      @db.Decimal(3, 2) @default(0)
  totalBookings   Int          @default(0)
  completionRate  Decimal      @db.Decimal(5, 2) @default(100)
  responseTime    Int?         // avg minutes to respond
  isVerified      Boolean      @default(false)
  isActive        Boolean      @default(true)

  listings        ServiceListing[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([latitude, longitude])
  @@index([type])
  @@index([district, state])
  @@index([kycStatus])
  @@map("service_providers")
}

model ServiceCategory {
  id              String   @id @default(cuid())
  name            Json     // { en: "Machinery", te: "యంత్రాలు", hi: "मशीनरी" }
  slug            String   @unique
  description     Json?    // multilingual description
  icon            String   @default("🔧")
  parentId        String?
  parent          ServiceCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children        ServiceCategory[] @relation("CategoryHierarchy")
  sortOrder       Int      @default(0)
  bookingType     BookingType @default(DAY)
  defaultUnit     PricingUnit @default(PER_DAY)
  requiresLicense Boolean  @default(false)
  isActive        Boolean  @default(true)

  listings        ServiceListing[]
  createdAt       DateTime @default(now())

  @@index([parentId])
  @@map("service_categories")
}

model ServiceListing {
  id                  String   @id @default(cuid())
  providerId          String
  provider            ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  categoryId          String
  category            ServiceCategory @relation(fields: [categoryId], references: [id])

  title               Json     // { en: "Tractor for hire", te: "అద్దెకు ట్రాక్టర్" }
  description         Json?    // multilingual
  images              String[] // S3 URLs
  pricingType         PricingType @default(FIXED)
  pricePerUnit        Decimal  @db.Decimal(10, 2)
  unit                PricingUnit @default(PER_DAY)
  minBookingDuration  Int      @default(1) // minimum booking in units

  // Equipment details (for machinery/drones)
  equipmentMake       String?
  equipmentModel      String?
  equipmentYear       Int?
  equipmentHP         Int?     // horsepower
  equipmentDetails    Json?    // flexible extra fields

  // Availability
  isActive            Boolean  @default(true)
  isPaused            Boolean  @default(false)
  seasonalAvailable   String[] // ["kharif", "rabi", "summer"]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([providerId])
  @@index([categoryId])
  @@index([isActive, isPaused])
  @@map("service_listings")
}
